# ─── DATABASE (NEON POSTGRESQL) ───────────────────────────
# Connection string from your Neon console dashboard
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ─── GOOGLE SHEETS (LIGHTWEIGHT CMS) ──────────────────────
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SHEETS_SPREADSHEET_ID=""
# Google Service Account client email
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Google Service Account private key (must include newlines '\n' correctly)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""

# ─── STORAGE (CLOUDFLARE R2) ──────────────────────────────
# Cloudflare account ID (from the R2 Dashboard URL/Sidebar)
R2_ACCOUNT_ID=""
# AWS S3 Access Key ID generated specifically for R2 bucket
R2_ACCESS_KEY_ID=""
# AWS S3 Secret Access Key generated specifically for R2 bucket
R2_SECRET_ACCESS_KEY=""
# The name of the bucket containing files
R2_BUCKET_NAME="blumbang"
# Custom domain or public bucket URL (optional)
R2_PUBLIC_URL=""

# ─── AUTH / SECURITY ──────────────────────────────────────
# Admin login credentials (REQUIRED — no fallback defaults)
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
# Session signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. REQUIRED.
SESSION_SECRET=""

# ─── APP SETTINGS ──────────────────────────────────────────
# Production site URL used for generating absolute paths in OG tags, sitemap, etc.
NEXT_PUBLIC_SITE_URL="https://blumbangkita.my.id"
# Target WhatsApp number for panitia CTAs (format: 628xxxxxxxx)
NEXT_PUBLIC_WHATSAPP_NUMBER=""
